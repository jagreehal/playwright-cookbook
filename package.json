{
  "name": "playwright-cookbook",
  "version": "1.0.0",
  "description": "A workshop-style guide to testing with Playwright, from your first browser test to a composed architecture for large suites",
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "test": "playwright test",
    "test:watch": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "PWDEBUG=1 playwright test",
    "test:record": "RECORD_FIXTURES=1 playwright test",
    "dev:web": "pnpm --filter playwright-cookbook-web dev",
    "lint": "eslint .",
    "typecheck": "pnpm --filter playwright-cookbook-web typecheck:i18n"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@eslint/js": "10.0.1",
    "@faker-js/faker": "10.4.0",
    "@playwright/test": "1.60.0",
    "@types/node": "25.9.1",
    "eslint": "10.4.1",
    "eslint-plugin-playwright": "2.10.4",
    "executable-stories-playwright": "8.4.4",
    "globals": "17.6.0",
    "serve": "14.2.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.1"
  },
  "dependencies": {
    "zod": "4.4.3"
  }
}
