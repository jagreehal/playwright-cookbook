---
import '../styles/tokens.css';
import '../styles/app.css';
import { href } from '../lib/url';

interface Props {
  title: string;
  description?: string;
  width?: 'prose' | 'wide';
  active?: 'cookbook' | 'docs';
}
const {
  title,
  description = 'A field manual for maintainable, non-flaky Playwright tests.',
  width = 'wide',
  active,
} = Astro.props;
const year = 2026;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- No-FOUC theme: resolve before first paint. -->
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('theme');
          const theme =
            saved === 'light' || saved === 'dark'
              ? saved
              : matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light';
          document.documentElement.dataset.theme = theme;
        } catch (_) {}
      })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=Spline+Sans+Mono:wght@400;500;600&family=Zilla+Slab:wght@400;500;600;700&display=swap"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="masthead">
      <div class="masthead__inner">
        <a class="wordmark" href={href('/')}>
          Playwright<span class="mark">·</span>Cookbook
        </a>
        <span class="masthead__tag">Field Manual</span>
        <nav class="masthead__nav" aria-label="Primary">
          <a href={href('/')} aria-current={active === 'cookbook' ? 'page' : undefined}>
            Cookbook
          </a>
          <button
            class="theme-toggle"
            type="button"
            aria-label="Toggle colour theme"
            data-theme-toggle
          >
            <svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
            </svg>
            <svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="4.2"></circle>
              <path
                d="M12 2v2.5M12 19.5V22M4.2 4.2l1.8 1.8M18 18l1.8 1.8M2 12h2.5M19.5 12H22M4.2 19.8 6 18M18 6l1.8-1.8"
              ></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main id="main" class={`shell ${width === 'prose' ? 'shell--prose' : ''}`}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <span>Playwright API Mocking Cookbook · {year}</span>
        <span class="label">page.route() done right</span>
      </div>
    </footer>

    <script is:inline>
      document
        .querySelector('[data-theme-toggle]')
        ?.addEventListener('click', () => {
          const root = document.documentElement;
          const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
          root.dataset.theme = next;
          try {
            localStorage.setItem('theme', next);
          } catch (_) {}
        });
    </script>
  </body>
</html>
