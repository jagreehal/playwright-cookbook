---
import CardLayout from '../../layouts/CardLayout.astro';
import Card20PersonFetcher from '../../components/cards/Card20PersonFetcher.astro';
import CodeBlock from '../../components/shared/CodeBlock.astro';
import ReadmeContent from '../../content/cards/20-api-seeding-cleanup.mdx';
---

<CardLayout title="API Seeding & Cleanup" cardNumber="20">
  <section class="readme">
    <ReadmeContent />
  </section>

  <section class="demo">
    <h2>Live Demo</h2>
    <p class="demo-label">
      👇 This component is what the Playwright test interacts with:
    </p>
    <div class="demo-container">
      <Card20PersonFetcher />
    </div>
  </section>

  <section class="test-info">
    <h2>Run This Example</h2>
    <CodeBlock language="bash" code="pnpm test src/20-api-seeding-cleanup" />
  </section>
</CardLayout>
