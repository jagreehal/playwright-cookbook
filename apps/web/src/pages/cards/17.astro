---
import CardLayout from '../../layouts/CardLayout.astro';
import Card17PersonFetcher from '../../components/cards/Card17PersonFetcher.astro';
import CodeBlock from '../../components/shared/CodeBlock.astro';
import ReadmeContent from '../../content/cards/17-accessibility-axe.mdx';
---

<CardLayout title="Accessibility with Axe" cardNumber="17">
  <section class="readme">
    <ReadmeContent />
  </section>

  <section class="demo">
    <h2>Live Demo</h2>
    <p class="demo-label">
      👇 This component is what the Playwright test interacts with:
    </p>
    <div class="demo-container">
      <Card17PersonFetcher />
    </div>
  </section>

  <section class="test-info">
    <h2>Run This Example</h2>
    <CodeBlock language="bash" code="pnpm test src/17-accessibility-axe" />
  </section>
</CardLayout>
