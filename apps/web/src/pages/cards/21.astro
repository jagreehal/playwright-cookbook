---
import CardLayout from '../../layouts/CardLayout.astro';
import Card21PersonFetcher from '../../components/cards/Card21PersonFetcher.astro';
import CodeBlock from '../../components/shared/CodeBlock.astro';
import ReadmeContent from '../../content/cards/21-app-driver-fixture.mdx';
---

<CardLayout title="App Driver Fixture" cardNumber="21">
  <section class="readme">
    <ReadmeContent />
  </section>

  <section class="demo">
    <h2>Live Demo</h2>
    <p class="demo-label">
      👇 This component is what the Playwright test interacts with:
    </p>
    <div class="demo-container">
      <Card21PersonFetcher />
    </div>
  </section>

  <section class="test-info">
    <h2>Run This Example</h2>
    <CodeBlock language="bash" code="pnpm test src/21-app-driver-fixture" />
  </section>
</CardLayout>
