---
import CardLayout from '../../layouts/CardLayout.astro';
import Card15PersonFetcher from '../../components/cards/Card15PersonFetcher.astro';
import CodeBlock from '../../components/shared/CodeBlock.astro';
import ReadmeContent from '../../content/cards/15-done-signals.mdx';
---

<CardLayout title="Done Signals" cardNumber="15">
  <section class="readme">
    <ReadmeContent />
  </section>

  <section class="demo">
    <h2>Live Demo</h2>
    <p class="demo-label">
      👇 This component is what the Playwright test interacts with:
    </p>
    <div class="demo-container">
      <Card15PersonFetcher />
    </div>
  </section>

  <section class="test-info">
    <h2>Run This Example</h2>
    <CodeBlock language="bash" code="pnpm test src/15-done-signals" />
  </section>
</CardLayout>
