---
import CardLayout from '../../layouts/CardLayout.astro';
import Card18PersonFetcher from '../../components/cards/Card18PersonFetcher.astro';
import CodeBlock from '../../components/shared/CodeBlock.astro';
import ReadmeContent from '../../content/cards/18-stability-techniques.mdx';
---

<CardLayout title="Stability Techniques" cardNumber="18">
  <section class="readme">
    <ReadmeContent />
  </section>

  <section class="demo">
    <h2>Live Demo</h2>
    <p class="demo-label">
      👇 This component is what the Playwright test interacts with:
    </p>
    <div class="demo-container">
      <Card18PersonFetcher />
    </div>
  </section>

  <section class="test-info">
    <h2>Run This Example</h2>
    <CodeBlock language="bash" code="pnpm test src/18-stability-techniques" />
  </section>
</CardLayout>
