---
import CardLayout from '../../layouts/CardLayout.astro';
import Card22PersonFetcher from '../../components/cards/Card22PersonFetcher.astro';
import CodeBlock from '../../components/shared/CodeBlock.astro';
import ReadmeContent from '../../content/cards/22-failure-artifacts.mdx';
---

<CardLayout title="Failure Artifacts" cardNumber="22">
  <section class="readme">
    <ReadmeContent />
  </section>

  <section class="demo">
    <h2>Live Demo</h2>
    <p class="demo-label">
      👇 This component is what the Playwright test interacts with:
    </p>
    <div class="demo-container">
      <Card22PersonFetcher />
    </div>
  </section>

  <section class="test-info">
    <h2>Run This Example</h2>
    <CodeBlock language="bash" code="pnpm test src/22-failure-artifacts" />
  </section>
</CardLayout>
