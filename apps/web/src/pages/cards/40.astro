---
import CardLayout from '../../layouts/CardLayout.astro';
import Card40ShadcnComponents from '../../components/cards/Card40ShadcnComponents.astro';
import CodeBlock from '../../components/shared/CodeBlock.astro';
import ReadmeContent from '../../content/cards/40-shadcn-components.mdx';

const cardNumber = '40';
const cardTitle = 'shadcn Components';
---

<CardLayout title={cardTitle} cardNumber={cardNumber}>
  <section class="readme">
    <ReadmeContent />
  </section>

  <section class="demo">
    <h2>Live Demo</h2>
    <p class="demo-label">
      👇 Real shadcn-on-base components, each built twice. The Playwright test
      drives the good and the bad version with the same query:
    </p>
    <div class="demo-container">
      <Card40ShadcnComponents />
    </div>
  </section>

  <section class="test-info">
    <h2>Run This Example</h2>
    <CodeBlock language="bash" code="pnpm test src/40-shadcn-components" />
  </section>
</CardLayout>
