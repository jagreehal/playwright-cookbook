import CodeBlock from '../../components/shared/CodeBlock.astro';
import ReadmeContent from '../../content/cards/14-region-objects.mdx';
---

<CardLayout title="Region Objects" cardNumber="14">
  <section class="readme">
    <ReadmeContent />
  </section>

  <section class="demo">
    <h2>Live Demo</h2>
    <p class="demo-label">
      👇 This component is what the Playwright test interacts with:
    </p>
    <div class="demo-container">
      <Card14PersonFetcher />
    </div>
  </section>

  <section class="test-info">
    <h2>Run This Example</h2>
    <CodeBlock language="bash" code="pnpm test src/14-region-objects" />
  </section>
</CardLayout>
