---
import CardLayout from '../../layouts/CardLayout.astro';
import Card23PersonFetcher from '../../components/cards/Card23PersonFetcher.astro';
import CodeBlock from '../../components/shared/CodeBlock.astro';
import ReadmeContent from '../../content/cards/23-api-only-tests.mdx';
---

<CardLayout title="API-Only Tests" cardNumber="23">
  <section class="readme">
    <ReadmeContent />
  </section>

  <section class="demo">
    <h2>Live Demo</h2>
    <p class="demo-label">
      👇 This component is what the Playwright test interacts with:
    </p>
    <div class="demo-container">
      <Card23PersonFetcher />
    </div>
  </section>

  <section class="test-info">
    <h2>Run This Example</h2>
    <CodeBlock language="bash" code="pnpm test src/23-api-only-tests" />
  </section>
</CardLayout>
