---
import CardLayout from '../../layouts/CardLayout.astro';
import Card13PersonFetcher from '../../components/cards/Card13PersonFetcher.astro';
import CodeBlock from '../../components/shared/CodeBlock.astro';
import ReadmeContent from '../../content/cards/13-scoped-queries.mdx';
---

<CardLayout title="Scoped Queries" cardNumber="13">
  <section class="readme">
    <ReadmeContent />
  </section>

  <section class="demo">
    <h2>Live Demo</h2>
    <p class="demo-label">
      👇 This component is what the Playwright test interacts with:
    </p>
    <div class="demo-container">
      <Card13PersonFetcher />
    </div>
  </section>

  <section class="test-info">
    <h2>Run This Example</h2>
    <CodeBlock language="bash" code="pnpm test src/13-scoped-queries" />
  </section>
</CardLayout>
