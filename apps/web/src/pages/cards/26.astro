---
import CardLayout from '../../layouts/CardLayout.astro';
import Card26PersonFetcher from '../../components/cards/Card26PersonFetcher.astro';
import CodeBlock from '../../components/shared/CodeBlock.astro';
import ReadmeContent from '../../content/cards/26-full-architecture.mdx';
---

<CardLayout title="Full Architecture" cardNumber="26">
  <section class="readme">
    <ReadmeContent />
  </section>

  <section class="demo">
    <h2>Live Demo</h2>
    <p class="demo-label">
      👇 This component is what the Playwright test interacts with:
    </p>
    <div class="demo-container">
      <Card26PersonFetcher />
    </div>
  </section>

  <section class="test-info">
    <h2>Run This Example</h2>
    <CodeBlock language="bash" code="pnpm test src/26-full-architecture" />
  </section>
</CardLayout>
