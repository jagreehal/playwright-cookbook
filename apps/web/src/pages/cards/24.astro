---
import CardLayout from '../../layouts/CardLayout.astro';
import Card24PersonFetcher from '../../components/cards/Card24PersonFetcher.astro';
import CodeBlock from '../../components/shared/CodeBlock.astro';
import ReadmeContent from '../../content/cards/24-parameterized-tests.mdx';
---

<CardLayout title="Parameterized Tests" cardNumber="24">
  <section class="readme">
    <ReadmeContent />
  </section>

  <section class="demo">
    <h2>Live Demo</h2>
    <p class="demo-label">
      👇 This component is what the Playwright test interacts with:
    </p>
    <div class="demo-container">
      <Card24PersonFetcher />
    </div>
  </section>

  <section class="test-info">
    <h2>Run This Example</h2>
    <CodeBlock language="bash" code="pnpm test src/24-parameterized-tests" />
  </section>
</CardLayout>
