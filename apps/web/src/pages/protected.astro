---
/**
 * Protected dashboard — same behavior as src/app/protected.html for Playwright tests.
 */
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard</title>
  </head>
  <body>
    <div id="app">
      <p>Checking auth…</p>
    </div>
    <script is:inline>
      if (!localStorage.getItem('auth')) {
        window.location.href = '/login';
      } else {
        document.getElementById('app').innerHTML =
          '<h1>Dashboard</h1><p data-testid="dashboard-message">Welcome, ' +
          (localStorage.getItem('user') || 'user') +
          '</p>';
      }
    </script>
  </body>
</html>
